{
  "name": "getshit",
  "version": "0.0.0",
  "private": true,
  "description": "Agent-first hierarchical task manager",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @getshit/core db:generate",
    "db:migrate": "pnpm --filter @getshit/core db:migrate"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "eslint": "^9.15.0",
    "@eslint/js": "^9.15.0",
    "typescript-eslint": "^8.16.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
