# --- Database -----------------------------------------------------------
GETSHIT_DB_URL=libsql://your-db.turso.io
GETSHIT_DB_AUTH_TOKEN=...

# --- File attachments ---------------------------------------------------
# Driver is auto-detected: if GETSHIT_S3_BUCKET + the two S3 credentials are
# set, S3 is used automatically; otherwise files are written under
# GETSHIT_FILES_DIR. Override the auto-detect with an explicit value:
#   GETSHIT_STORAGE=s3     — force S3 (errors if creds are missing)
#   GETSHIT_STORAGE=local  — force local even if S3 creds are present
# GETSHIT_STORAGE=
GETSHIT_FILES_DIR=./data/files
GETSHIT_MAX_UPLOAD_MB=25

# S3 adapter — fill these in to auto-select S3.
# GETSHIT_S3_BUCKET=
# GETSHIT_S3_REGION=auto
# GETSHIT_S3_ENDPOINT=     # optional, set for R2/MinIO/non-AWS
# GETSHIT_S3_ACCESS_KEY_ID=
# GETSHIT_S3_SECRET_ACCESS_KEY=

# --- Auth ---------------------------------------------------------------
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Optional dev-only credentials fallback (skip Google during local dev)
# AUTH_DEV_USERNAME=
# AUTH_DEV_PASSWORD=
# AUTH_DEV_USER_ID=

# --- LLM (optional) -----------------------------------------------------
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
