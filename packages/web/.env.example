# --- Database -----------------------------------------------------------
GETSHIT_DB_URL=libsql://your-db.turso.io
GETSHIT_DB_AUTH_TOKEN=...

# --- File attachments ---------------------------------------------------
# local (default) — files written under GETSHIT_FILES_DIR
# s3              — any S3-compatible bucket (AWS, Cloudflare R2, MinIO, B2)
GETSHIT_STORAGE=local
GETSHIT_FILES_DIR=./data/files
GETSHIT_MAX_UPLOAD_MB=25

# S3 adapter (only required when GETSHIT_STORAGE=s3)
# GETSHIT_S3_BUCKET=
# GETSHIT_S3_REGION=auto
# GETSHIT_S3_ENDPOINT=     # optional, set for R2/MinIO/non-AWS
# GETSHIT_S3_ACCESS_KEY_ID=
# GETSHIT_S3_SECRET_ACCESS_KEY=

# --- Auth ---------------------------------------------------------------
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Optional dev-only credentials fallback (skip Google during local dev)
# AUTH_DEV_USERNAME=
# AUTH_DEV_PASSWORD=
# AUTH_DEV_USER_ID=

# --- LLM (optional) -----------------------------------------------------
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
